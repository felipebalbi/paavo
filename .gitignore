/target
**/*.rs.bk
Cargo.lock.bak
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Git worktrees for isolated feature work (using-git-worktrees skill).
/.worktrees/

# Brainstorming visual-companion mockups (superpowers skill scratch space).
/.superpowers/

# paavod runtime state (when run locally for dev)
/var-paavo/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Standalone test-fixture crates have their own target dirs and their
# own Cargo.lock files. The fixtures themselves are checked in; their
# build outputs are not.
/tests/fixtures/*/target
/tests/fixtures/*/Cargo.lock
/soak-tests/*/*/target
/soak-tests/*/*/Cargo.lock
# M7.0 spike crates — same rule. Source files checked in; target/ +
# Cargo.lock are local-only because they're standalone, run-by-hand
# binaries that nothing else in CI depends on.
/dev/*/target
/dev/*/Cargo.lock
